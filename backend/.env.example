# Django
SECRET_KEY=tu_clave_secreta_aqui
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos (desarrollo usa SQLite por defecto)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# Para producción con PostgreSQL descomentar:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=runners_db
# DB_USER=runners_user
# DB_PASSWORD=tu_password
# DB_HOST=localhost
# DB_PORT=5432

# Media
MEDIA_URL=/media/
MEDIA_ROOT=media/

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://10.0.2.2:8000,http://localhost:8000
CORS_ALLOW_ALL_ORIGINS_DEV=True

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# Correo (recuperacion de contrasena)
# Si defines EMAIL_HOST_USER y EMAIL_HOST_PASSWORD, el backend usara SMTP automaticamente.
# Para Gmail usa una App Password de 16 caracteres.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu_correo@gmail.com
EMAIL_HOST_PASSWORD=tu_app_password
DEFAULT_FROM_EMAIL=Runners <tu_correo@gmail.com>
APP_NAME=Runners
